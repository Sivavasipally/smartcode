# --- provider API keys (only for the providers you use) ---
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# --- smartcode settings (all optional; defaults shown) ---
# NOTE: keep comments on their own line — inline "VALUE  # comment" is not
# reliably stripped and becomes part of the value.

# provider: local | groq | anthropic | openai | google | mock
SMARTCODE_PROVIDER=groq
SMARTCODE_LOCAL_MODEL_PATH=D:/models/Qwen2.5-1.5B-Instruct
# device: auto | cuda | cpu     dtype: auto | fp16 | fp32
SMARTCODE_LOCAL_DEVICE=auto
SMARTCODE_LOCAL_DTYPE=auto
SMARTCODE_GROQ_MODEL=llama-3.3-70b-versatile
SMARTCODE_ANTHROPIC_MODEL=claude-sonnet-4-5
SMARTCODE_OPENAI_MODEL=gpt-4.1
SMARTCODE_GOOGLE_MODEL=gemini-2.0-flash
SMARTCODE_MAX_REVISIONS=3
SMARTCODE_CONTEXT_TOKEN_BUDGET=6000
# risk tier: low = auto-apply, medium = confirm, high = explicit approval
SMARTCODE_DEFAULT_RISK_TIER=medium
SMARTCODE_RUN_LINTERS=true
SMARTCODE_RUN_TESTS=true
# test command, e.g. "pytest -q" — tests only run when set
SMARTCODE_TEST_COMMAND=
SMARTCODE_DATA_DIR=.smartcode
SMARTCODE_ENABLE_CHECKPOINTER=true
SMARTCODE_ENABLE_HITL=true
SMARTCODE_VERBOSE=false
